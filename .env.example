# --- Primary LLM ---
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Fallback LLM (used selectively for Synthesizer streaming) ---
# Get from https://console.groq.com/keys
GROQ_API_KEY=

# --- Web search ---
# Get from https://app.tavily.com/home (free tier: 1000 credits/month)
TAVILY_API_KEY=

# --- GitHub researcher ---
# Get from https://github.com/settings/tokens (classic token; scopes: public_repo, read:user)
GITHUB_TOKEN=

# --- Tracing (optional) ---
# Get from https://smith.langchain.com (free tier: 5000 traces/month)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-research-analyst
LANGCHAIN_TRACING_V2=true

# --- App config (defaults — override if needed) ---
DEFAULT_LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MAX_CONCURRENT_CALLS=5
CACHE_DIR=.cache
